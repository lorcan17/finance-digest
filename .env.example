# finance-digest — example env file. Copy to .env for local dev.
# On NixOS secrets come from agenix; only NTFY_URL and QUESTRADE_DB_PATH are needed.

FMP_API_KEY=
ANTHROPIC_API_KEY=
NTFY_URL=https://ntfy.yourdomain.com/your-topic

# Path to questrade-extract database
# Dev default: ~/projects/questrade-extract/db/questrade.db
# NixOS: set to /var/lib/questrade-extract/questrade.db
# QUESTRADE_DB_PATH=

# Claude model (default: claude-haiku-4-5-20251001 — cheap for daily digest)
# AI_MODEL=claude-haiku-4-5-20251001

# OTel collector endpoint (default: http://localhost:4317)
# Dev: point at otel-gui (github.com/metafab/otel-gui) for zero-config local metric inspection
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
